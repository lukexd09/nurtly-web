---
const { intro, sections } = Astro.props;
---
<main class="card">
  <p style="margin-top: 0; color: var(--sage-dark); font-weight: 700;">Support</p>
  <p>{intro}</p>
  {sections.map((section) => (
    <section style="margin-top: 1.25rem;">
      <h2 style="margin-bottom: 0.5rem; font-size: 1.2rem;">{section.heading}</h2>
      <p style="margin: 0; color: var(--text);">{section.body}</p>
    </section>
  ))}
</main>
