---
const {
  title,
  description,
  lang,
  path,
  hreflangEn,
  hreflangPl,
  xDefault,
} = Astro.props;
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={`https://nurtly.graylion.pl${path}`} />
    <link rel="alternate" hreflang="en" href={`https://nurtly.graylion.pl${hreflangEn}`} />
    <link rel="alternate" hreflang="pl" href={`https://nurtly.graylion.pl${hreflangPl}`} />
    {xDefault && <link rel="alternate" hreflang="x-default" href={`https://nurtly.graylion.pl${xDefault}`} />}
    <style>
      :root {
        color-scheme: light;
        --bg: #f7f4ee;
        --panel: #fdfbf6;
        --text: #25313a;
        --muted: #5d6a72;
        --border: #cfd8d4;
        --sage: #6f8478;
        --sage-dark: #55685d;
        --beige: #e8dcc7;
        --link: #355c6d;
        --focus: #1d4ed8;
      }
      html {
        background: var(--bg);
        color: var(--text);
        font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        line-height: 1.6;
      }
      body {
        margin: 0;
        min-height: 100vh;
        background: var(--bg);
        color: var(--text);
      }
      a { color: var(--link); }
      a:hover { color: var(--sage-dark); }
      a:focus-visible,
      button:focus-visible {
        outline: 3px solid var(--focus);
        outline-offset: 2px;
      }
      .shell {
        max-width: 800px;
        margin: 0 auto;
        padding: 1rem;
      }
      .card {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 1rem;
      }
      @media (min-width: 720px) {
        .shell { padding: 2rem; }
        .card { padding: 1.5rem; }
      }
    </style>
  </head>
  <body>
    <div class="shell">
      <slot />
    </div>
  </body>
</html>
