---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import LanguageSwitcher from "../../components/LanguageSwitcher.astro";
import PolicyPage from "../../components/PolicyPage.astro";
import { privacyContent } from "../../data/privacy";
---
<BaseLayout title={privacyContent.en.title} description={privacyContent.en.description} lang="en" path="/privacy/en" hreflangEn="/privacy/en" hreflangPl="/privacy/pl" xDefault="/privacy">
  <LanguageSwitcher currentLang="en" enHref="/privacy/en" plHref="/privacy/pl" />
  <Header title={privacyContent.en.title} versionLabel={privacyContent.en.versionLabel} updatedLabel={privacyContent.en.updatedLabel} updatedValue={privacyContent.en.updatedValue} />
  <PolicyPage intro={privacyContent.en.intro} sections={privacyContent.en.sections} pageLabel={privacyContent.en.pageLabel} />
  <Footer product="Nurtly" operator="GRAY LION ŁUKASZ CHMIEL" email="nurtly@graylion.pl" />
</BaseLayout>
