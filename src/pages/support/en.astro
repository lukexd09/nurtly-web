---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import LanguageSwitcher from "../../components/LanguageSwitcher.astro";
import SupportPage from "../../components/SupportPage.astro";
import { supportContent } from "../../data/support";
---
<BaseLayout title={supportContent.en.title} description={supportContent.en.description} lang="en" path="/support/en" hreflangEn="/support/en" hreflangPl="/support/pl">
  <LanguageSwitcher currentLang="en" enHref="/support/en" plHref="/support/pl" />
  <Header title={supportContent.en.title} versionLabel={supportContent.en.versionLabel} updatedLabel={supportContent.en.updatedLabel} updatedValue={supportContent.en.updatedValue} />
  <SupportPage intro={supportContent.en.intro} sections={supportContent.en.sections} pageLabel={supportContent.en.pageLabel} />
  <Footer product="Nurtly" operator="GRAY LION ŁUKASZ CHMIEL" email="nurtly@graylion.pl" />
</BaseLayout>
