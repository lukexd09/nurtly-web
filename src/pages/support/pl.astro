---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import LanguageSwitcher from "../../components/LanguageSwitcher.astro";
import SupportPage from "../../components/SupportPage.astro";
import { supportContent } from "../../data/support";
---
<BaseLayout title={supportContent.pl.title} description={supportContent.pl.description} lang="pl" path="/support/pl" hreflangEn="/support/en" hreflangPl="/support/pl">
  <LanguageSwitcher currentLang="pl" enHref="/support/en" plHref="/support/pl" />
  <Header title={supportContent.pl.title} versionLabel={supportContent.pl.versionLabel} updatedLabel={supportContent.pl.updatedLabel} updatedValue={supportContent.pl.updatedValue} />
  <SupportPage intro={supportContent.pl.intro} sections={supportContent.pl.sections} pageLabel={supportContent.pl.pageLabel} />
  <Footer product="Nurtly" operator="GRAY LION ŁUKASZ CHMIEL" email="nurtly@graylion.pl" />
</BaseLayout>
